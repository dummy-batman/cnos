#include <stdio.h>

int main() {
    int frames[10], pages[50];
    int n, f, i, j, k = 0, flag, faults = 0;

    printf("Enter no of frames: ");
    scanf("%d", &f);
    printf("Enter no of reference string: ");
    scanf("%d", &n);

    printf("Enter reference string:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &pages[i]);
    }

    for(i = 0; i < f; i++)
        frames[i] = -1;

    for(i = 0; i < n; i++) {
        flag = 0;
        for(j = 0; j < f; j++) {
            if(frames[j] == pages[i]) {
                flag = 1;
                break;
            }
        }
        if(flag == 0) {
            frames[k] = pages[i];
            k = (k + 1) % f;
            faults++;
        }
        printf("Ref %d -> ", pages[i]);
        for(j = 0; j < f; j++) {
            if(frames[j] != -1)
                printf("%d ", frames[j]);
        }
        printf("\n");
    }

    printf("\nTotal Page Faults: %d\n", faults);
    return 0;
}
