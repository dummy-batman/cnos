#include <stdio.h>

int main() {
    int base[10], limit[10], val[10][10];
    int n, i, j, seg, offset, physical;

    printf("Enter the size of the segment table: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("\nEnter info about segment %d\n", i);
        printf("Enter base address: ");
        scanf("%d", &base[i]);
        printf("Enter the limit: ");
        scanf("%d", &limit[i]);
        for(j = 0; j < limit[i]; j++) {
            printf("Enter %d address value: ", base[i] + j);
            scanf("%d", &val[i][j]);
        }
    }

    printf("\nSeg.no\tBase\tLimit\n");
    for(i = 0; i < n; i++) {
        printf("%d\t%d\t%d\n", i, base[i], limit[i]);
    }

    printf("\nEnter segment no: ");
    scanf("%d", &seg);

    if(seg >= n) {
        printf("Invalid segment number\n");
        return 0;
    }

    printf("Enter the logical address (offset): ");
    scanf("%d", &offset);

    if(offset >= limit[seg]) {
        printf("Invalid offset\n");
    } else {
        physical = base[seg] + offset;
        printf("Mapped physical address is: %d\n", physical);
        printf("The value is: %d\n", val[seg][offset]);
    }

    return 0;
}
