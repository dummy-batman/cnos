#include <stdio.h>

int main() {
    int bits[50], n, i, j, count = 0;

    printf("Enter number of bits: ");
    scanf("%d", &n);

    printf("Enter the bits: ");
    for (i = 0; i < n; i++) {
        scanf("%d", &bits[i]);
    }

    for (i = 0; i < n; i++) {
        if (bits[i] == 1) {
            count++;
        } else {
            count = 0;
        }

        if (count == 5) {
            for (j = n; j > i; j--) {
                bits[j + 1] = bits[j];
            }
            bits[i + 1] = 0;
            n++;     
            count = 0; 
            i++;     
        }
    }

    printf("Stuffed Data: 01111110 ");
    for (i = 0; i < n; i++) {
        printf("%d", bits[i]);
    }
    printf(" 01111110\n");

    return 0;
}
