#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>

int global = 10;

int main() {
    int local = 20;
    pid_t pid;

    printf("Before fork\n");
    printf("pid = %d, global = %d, local = %d\n", getpid(), global, local);

    pid = fork();

    if(pid == 0) {
        global++;
        local++;
        printf("After fork (Child)\n");
        printf("pid = %d, global = %d, local = %d\n", getpid(), global, local);
    } else {
        sleep(1); 
        global++;
        printf("After fork (Parent)\n");
        printf("pid = %d, global = %d, local = %d\n", getpid(), global, local);
    }

    return 0;
}
