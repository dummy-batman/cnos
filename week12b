#include <stdio.h>

int main() {
    int f, n, i, j, pages[20], frames[10], time[10];
    int fault = 0, found, min;

    printf("Frames: ");
    scanf("%d", &f);

    printf("Pages: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
        scanf("%d", &pages[i]);

    for(i = 0; i < f; i++) {
        frames[i] = -1;
        time[i] = -1;
    }

    for(i = 0; i < n; i++) {
        found = 0;

        for(j = 0; j < f; j++) {
            if(frames[j] == pages[i]) {
                found = 1;
                time[j] = i;
                break;
            }
        }

        if(!found) {
            min = 0;
            for(j = 1; j < f; j++)
                if(time[j] < time[min]) min = j;

            frames[min] = pages[i];
            time[min] = i;
            fault++;
        }
    }

    printf("Page faults = %d", fault);

    return 0;
}
