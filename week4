#include <stdio.h>

#define MAX 10
#define INF 9999

int main()
{
    int n, i, j, start;
    int cost[MAX][MAX], dist[MAX], visited[MAX];

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for(i = 0; i < n; i++)
    {
        for(j = 0; j < n; j++)
        {
            scanf("%d", &cost[i][j]);

            if(cost[i][j] == 0 && i != j)
                cost[i][j] = INF;
        }
    }

    printf("Enter starting vertex: ");
    scanf("%d", &start);

    // Initialize
    for(i = 0; i < n; i++)
    {
        dist[i] = cost[start][i];
        visited[i] = 0;
    }

    dist[start] = 0;
    visited[start] = 1;

    // Main logic
    for(i = 0; i < n - 1; i++)
    {
        int min = INF, u = -1;

        // Find minimum distance
        for(j = 0; j < n; j++)
        {
            if(visited[j] == 0 && dist[j] < min)
            {
                min = dist[j];
                u = j;
            }
        }

        visited[u] = 1;

        // Update distances
        for(j = 0; j < n; j++)
        {
            if(visited[j] == 0)
            {
                if(dist[u] + cost[u][j] < dist[j])
                {
                    dist[j] = dist[u] + cost[u][j];
                }
            }
        }
    }

    // Output
    printf("\nShortest distances:\n");
    for(i = 0; i < n; i++)
    {
        printf("%d -> %d = %d\n", start, i, dist[i]);
    }

    return 0;
}
