#include <stdio.h>

int main() {
    int n, b[10], sb[10], i, x;

    printf("Enter number of files: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("Blocks and start of file %d: ", i+1);
        scanf("%d %d", &b[i], &sb[i]);
    }

    printf("\nFile\tStart\tLength\n");
    for(i = 0; i < n; i++) {
        printf("%d\t%d\t%d\n", i+1, sb[i], b[i]);
    }

    printf("\nEnter file number: ");
    scanf("%d", &x);

    printf("Blocks: ");
    for(i = 0; i < b[x-1]; i++) {
        printf("%d ", sb[x-1] + i);
    }

    return 0;
}
